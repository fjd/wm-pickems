# Copy to .env and adjust. Consumed by docker-compose and the app.

# Port the server listens on (host side).
HTTP_PORT=8090

# Live results source.
#   - Default (auto): use API-Football only if its key can reach WC2026 (a
#     PAID plan — the free tier excludes season 2026), otherwise pull the
#     free community openfootball JSON. Manual admin override always works.
#   - Force with RESULTS_SOURCE = apifootball | openfootball | auto
API_FOOTBALL_KEY=
RESULTS_SOURCE=auto
# Optional: override the results-sync cadence (cron). Default: */30 * * * *.
# Tighten (e.g. */5 * * * *) for near-instant scores during matches.
SYNC_CRON=

# Initial PocketBase superuser, created on first boot if set.
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# Email notifications. The notify scheduler sends stage-start / forecast /
# tips reminders and a daily results recap (each user opts in/out per event
# under Settings → Notifications; lead time defaults to 12h).
#
# Provider is swappable. MAIL_PROVIDER = resend | mailjet | smtp | log | (blank = auto):
#   - resend  : Resend API (set RESEND_API_KEY below). Recommended.
#   - mailjet : Mailjet Send API v3.1 (set the two keys below).
#   - smtp    : whatever SMTP is configured in the PocketBase dashboard
#               (also covers Mailjet's SMTP relay). No provider message id.
#   - log     : log only, never delivers (handy for local/dev).
#   - auto    : resend if its key is set, else mailjet if its keys are set,
#               else smtp if enabled, else log.
# The chosen provider also carries PocketBase's built-in emails (account
# verification, password reset), so PB's SMTP settings stay untouched. Note:
# notification emails only go to users with a VERIFIED email address.
MAIL_PROVIDER=
RESEND_API_KEY=
MAILJET_API_KEY=
MAILJET_SECRET=
# Sender identity. Falls back to PocketBase's configured sender if blank.
# The address must be on a verified domain/sender of your mail provider.
MAIL_FROM=
MAIL_FROM_NAME=WM Pickems
# Optional: override the scheduler cadence (cron). Default: */15 * * * *
NOTIFY_CRON=
# Disable the notify scheduler entirely (1/true/yes/on). Handy for local
# testing — no automated mail/push is sent; dev manual-trigger routes still work.
NOTIFY_DISABLED=
# Log verbosity. Default (unset/"info"): only log passes that sent/failed mail
# (plus allowlist changes and errors). Set to "debug" for a per-pass heartbeat.
NOTIFY_LOG_LEVEL=
# Web Push (VAPID). Optional: if unset, a keypair is generated on first boot
# and stored in the DB (app_meta). Pin these to keep keys stable across a
# pb_data wipe — regenerated keys invalidate every existing push subscription.
# Generate a pair once with any web-push tool, or copy them out of app_meta.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact for the VAPID JWT (mailto: or https:). Defaults to mailto:<MAIL_FROM>.
VAPID_SUBJECT=

# Gradual rollout allowlist: comma-separated emails that may receive mail.
# Empty = everyone. Can also be set/expanded at runtime (no redeploy) via the
# `allowlist` field of the notify_config row in the app_meta collection, which
# takes precedence over this env seed when non-empty.
NOTIFY_ALLOWLIST=

# Google sign-in. From a Google Cloud OAuth 2.0 Client (type: Web
# application). Authorized redirect URI must be:
#   <public-url>/api/oauth2-redirect
# Leave blank to disable Google sign-in (app still runs normally).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# League chat notifications (private leagues only).
# Optional cron overrides:
#   CHAT_NOTIFY_CRON  push cadence  — default "* * * * *"   (every minute)
#   CHAT_DIGEST_CRON  email digest  — default "0 */6 * * *" (every 6 hours)
CHAT_NOTIFY_CRON=
CHAT_DIGEST_CRON=

# In-chat GIF picker (KLIPY). Get a free key at https://klipy.com/developers.
# Leave blank to disable GIFs (the picker shows "not set up yet"). The key
# stays server-side — GIF search is proxied through the app.
KLIPY_API_KEY=
